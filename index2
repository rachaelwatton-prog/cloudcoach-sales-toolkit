
<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cloud Coach Sales Toolkit</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',sans-serif;background:#f5f5f3;color:#1a1a18;font-size:14px;line-height:1.6}
.app{max-width:900px;margin:0 auto;padding:24px 16px}
.header{margin-bottom:24px}
.header h1{font-size:22px;font-weight:500;margin-bottom:4px}
.header p{font-size:13px;color:#6b6b66}
.tab-bar{display:flex;gap:4px;margin-bottom:24px;border-bottom:1px solid #e0ded6;padding-bottom:0;flex-wrap:wrap}
.tab{padding:10px 16px;font-size:13px;cursor:pointer;border:none;background:none;color:#6b6b66;border-bottom:2px solid transparent;margin-bottom:-1px;transition:all 0.15s;font-family:inherit;white-space:nowrap}
.tab:hover{color:#1a1a18}
.tab.active{color:#1a1a18;font-weight:500;border-bottom-color:#1a1a18}
.section{display:none}.section.active{display:block}
.nav-pills{display:flex;gap:6px;flex-wrap:wrap;margin-bottom:20px}
.npill{padding:7px 13px;border:1px solid #d3d1c7;border-radius:8px;background:transparent;color:#6b6b66;font-size:12px;cursor:pointer;transition:all 0.15s;white-space:nowrap;font-family:inherit}
.npill:hover{background:#f0efe8}
.card{background:#fff;border:1px solid #e0ded6;border-radius:12px;padding:20px;margin-bottom:12px}
.sec-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#9b9990;margin:18px 0 8px}
.pill{font-size:12px;color:#5f5e5a;background:#f0efe8;border-radius:20px;padding:4px 10px;display:inline-block;margin:3px 3px 3px 0}
.grid2{display:grid;grid-template-columns:1fr 1fr;gap:10px}
.mc{background:#f7f6f2;border-radius:8px;padding:12px;font-size:13px}
.mc p{margin:0;color:#5f5e5a;line-height:1.6}
.mc strong{display:block;font-weight:600;color:#1a1a18;margin-bottom:4px;font-size:12px}
.dot-row{display:flex;gap:8px;align-items:flex-start;margin-bottom:8px}
.dot{width:6px;height:6px;border-radius:50%;flex-shrink:0;margin-top:5px}
.dot-red{background:#e24b4a}
.dot-green{background:#639922}
.dot-blue{background:#378add}
.dot-row p{font-size:13px;color:#5f5e5a;margin:0;line-height:1.6}
.meta-chip{font-size:11px;padding:3px 10px;border-radius:6px;border:1px solid #d3d1c7;color:#6b6b66;display:inline-block;margin:2px}
.accent-left{border-left:2px solid #378add;padding:10px 14px;border-radius:0 8px 8px 0;background:#f0f7ff;margin-bottom:12px}
.accent-left p{font-size:13px;color:#5f5e5a;margin:0;line-height:1.6}
.tag-c{background:#faeeda;color:#633806;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-u{background:#e6f1fb;color:#0c447c;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-t{background:#e1f5ee;color:#085041;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-e{background:#fbeaf0;color:#72243e;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-m{background:#eeedfe;color:#3c3489;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-d{background:#e1f5ee;color:#085041;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-p{background:#faece7;color:#712b13;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-i{background:#fbeaf0;color:#72243e;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-ch{background:#eaf3de;color:#27500a;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.tag-co{background:#f1efe8;color:#444441;border-radius:20px;padding:3px 10px;font-size:12px;display:inline-block;margin-bottom:6px}
.s0a{background:#f0efe8;color:#1a1a18;border-color:transparent;font-weight:500}
.s1a{background:#eeedfe;color:#3c3489;border-color:transparent;font-weight:500}
.s2a{background:#e6f1fb;color:#0c447c;border-color:transparent;font-weight:500}
.s3a{background:#e1f5ee;color:#085041;border-color:transparent;font-weight:500}
.s4a{background:#faeeda;color:#633806;border-color:transparent;font-weight:500}
.s5a{background:#eaf3de;color:#27500a;border-color:transparent;font-weight:500}
.gong-quote{background:#faeeda;border-left:3px solid #ba7517;border-radius:0 8px 8px 0;padding:12px 14px;margin:12px 0}
.gong-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#633806;margin-bottom:6px}
.gong-quote p{font-size:13px;color:#633806;line-height:1.7;margin:0;font-style:italic}
.why-box{background:#f7f6f2;border-radius:8px;padding:12px;margin:8px 0}
.why-box p{font-size:13px;color:#5f5e5a;line-height:1.7;margin:0}
.say-row{display:flex;gap:10px;align-items:flex-start;margin-bottom:8px}
.say-dot{width:6px;height:6px;border-radius:50%;background:#639922;flex-shrink:0;margin-top:6px}
.say-row p{font-size:13px;color:#5f5e5a;line-height:1.7;margin:0;font-style:italic}
.principle-box{border-left:2px solid #378add;padding:10px 14px;border-radius:0 8px 8px 0;background:#f0f7ff;margin-top:12px}
.principle-box p{font-size:13px;color:#1a5276;margin:0;line-height:1.7}
.rule-card{background:#fff;border:1px solid #e0ded6;border-radius:12px;padding:1.5rem;margin-top:4px;text-align:center}
.rule-card h3{font-size:16px;font-weight:500;margin-bottom:12px}
.rule-card .big{font-size:15px;font-style:italic;color:#5f5e5a;line-height:1.7;max-width:560px;margin:0 auto 12px}
.rule-card p{font-size:13px;color:#9b9990;line-height:1.7;max-width:560px;margin:0 auto}
.rp-intro{background:#f7f6f2;border-radius:12px;padding:1.25rem;margin-bottom:20px}
.rp-intro p{font-size:13px;color:#5f5e5a;line-height:1.7;margin:0}
.scenario-card{background:#fff;border:1px solid #e0ded6;border-radius:12px;padding:20px;margin-bottom:16px}
.scenario-header{display:flex;align-items:flex-start;justify-content:space-between;gap:12px;margin-bottom:12px;flex-wrap:wrap}
.scenario-num{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#9b9990}
.scenario-tag{font-size:11px;padding:3px 10px;border-radius:20px;background:#eeedfe;color:#3c3489}
.prospect-says{background:#f0f7ff;border-left:3px solid #378add;border-radius:0 8px 8px 0;padding:12px 14px;margin:12px 0}
.prospect-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#0c447c;margin-bottom:4px}
.prospect-says p{font-size:13px;color:#0c447c;line-height:1.7;margin:0;font-style:italic}
.rp-textarea{width:100%;border:1px solid #d3d1c7;border-radius:8px;padding:12px;font-size:13px;font-family:inherit;line-height:1.6;color:#1a1a18;background:#fff;resize:vertical;min-height:100px;margin-top:8px}
.rp-textarea:focus{outline:none;border-color:#378add}
.rp-btn{padding:10px 20px;font-size:13px;cursor:pointer;border-radius:8px;border:1px solid #d3d1c7;background:#1a1a18;color:#fff;font-family:inherit;margin-top:8px;transition:all 0.15s}
.rp-btn:hover{background:#333}
.rp-btn:disabled{background:#d3d1c7;cursor:not-allowed;color:#9b9990}
.feedback-box{margin-top:16px;border:1px solid #e0ded6;border-radius:12px;overflow:hidden}
.feedback-header{background:#f7f6f2;padding:12px 16px;font-size:12px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#9b9990}
.feedback-body{padding:16px}
.feedback-body p{font-size:13px;color:#5f5e5a;line-height:1.7;margin-bottom:12px}
.feedback-body p:last-child{margin-bottom:0}
.feedback-dim{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.06em;color:#9b9990;margin:12px 0 4px}
.score-row{display:flex;gap:8px;align-items:center;margin-bottom:8px}
.score-bar-wrap{flex:1;background:#f0efe8;border-radius:4px;height:6px;overflow:hidden}
.score-bar{height:6px;border-radius:4px;background:#378add;transition:width 0.4s}
.score-label{font-size:12px;color:#5f5e5a;min-width:32px;text-align:right}
.dim-label{font-size:12px;color:#5f5e5a;min-width:140px}
.model-response{background:#eaf3de;border-left:3px solid #639922;border-radius:0 8px 8px 0;padding:12px 14px;margin-top:12px}
.model-label{font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#27500a;margin-bottom:6px}
.model-response p{font-size:13px;color:#27500a;line-height:1.7;margin:0}
.loading-indicator{font-size:13px;color:#9b9990;font-style:italic;margin-top:12px}
.footer-note{font-size:11px;color:#9b9990;text-align:center;margin-top:20px;padding-top:12px;border-top:1px solid #e0ded6}
@media(max-width:600px){.grid2{grid-template-columns:1fr}.tab{padding:8px 10px;font-size:12px}}
</style>
</head>
<body>
<div class="app">
  <div class="header">
    <h1>Cloud Coach Sales Toolkit</h1>
    <p>CUTE personas · MEDDPICC qualification · Stage advancement · Objection handling · Role play</p>
  </div>
  <div class="tab-bar">
    <button class="tab active" onclick="switchTab('cute')">CUTE Personas</button>
    <button class="tab" onclick="switchTab('medd')">MEDDPICC</button>
    <button class="tab" onclick="switchTab('stage')">Stage Advancement</button>
    <button class="tab" onclick="switchTab('obj')">Commercial Objection Handling</button>
    <button class="tab" onclick="switchTab('rplay')">Commercial Objection Handling Role Play</button>
  </div>
  <div id="cute" class="section active"><div class="nav-pills" id="cute-nav"></div><div id="cute-panel"></div></div>
  <div id="medd" class="section"><div class="nav-pills" id="medd-nav"></div><div id="medd-panel"></div></div>
  <div id="stage" class="section"><div class="nav-pills" id="stage-nav"></div><div id="stage-panel"></div></div>
  <div id="obj" class="section"><div class="nav-pills" id="obj-nav"></div><div id="obj-panel"></div></div>
  <div id="rplay" class="section"><div id="rplay-panel"></div></div>
</div>
<script>
function switchTab(id){
  document.querySelectorAll('.tab').forEach(function(t,i){t.classList.toggle('active',['cute','medd','stage','obj','rplay'][i]===id);});
  document.querySelectorAll('.section').forEach(function(s){s.classList.remove('active');});
  document.getElementById(id).classList.add('active');
}
var cuteData={
  c:{label:'C — Champion',name:'Champion',role:'Internal advocate — drives the deal from inside',who:'Typically a Director or VP of Professional Services, Customer Success, or Operations. They feel the pain most acutely and want the problem solved. At Cloud Coach this is likely the person who owns onboarding, project delivery, or resource management.',identify:['Asks detailed outcome questions not feature questions','Has tried to solve this internally with spreadsheets or workarounds','Brings colleagues into calls unprompted','Shares internal data or org context voluntarily','Uses language like we have been struggling with this'],reach:['Ask your entry contact who owns the day-to-day pain around onboarding or project delivery','Look for Directors or VPs in PS, CS, or Ops on LinkedIn before the call','In discovery ask who would need to champion a change like this internally'],tactics:[{t:'Co-build the business case',b:'Give them a template. Champions want to look good internally — equip them with ROI numbers, a one-pager, and talking points they can use in internal meetings without you in the room.'},{t:'Reference stories',b:'Share a relevant customer story. Champions repeat these stories — make them easy to retell.'},{t:'Keep them warm between calls',b:'Short useful touchpoints — a relevant article, a product update, a quick check-in. Champions go cold if you only contact them when you need something.'},{t:'Help them navigate their EB',b:'Coach the Champion on how to get budget approval. Prep them with the language the CFO or CEO responds to: cost reduction, risk mitigation, competitive positioning.'}],bizcase:'Frame value around their personal win: fewer fires, smoother delivery, better team utilisation. Tie to metrics they already track — onboarding cycle time, project margin, resource utilisation %. Show how Cloud Coach owns the workflow layer so their team stops doing manual coordination in spreadsheets.',ibg:'#faeeda',ic:'#633806',btnStyle:'background:#faeeda;color:#633806;border-color:transparent;font-weight:500'},
  u:{label:'U — User',name:'User',role:'Day-to-day operator — adoption depends on their buy-in',who:'Project managers, customer success managers, resource planners, implementation consultants. They will live inside the product every day. Their concerns are practical: is it easy to use, does it replace multiple tools, will it break mid-project?',identify:['Asks how does this actually work in practice','Concerned about migration, training, and disruption','May be skeptical — they have seen tools come and go','Often on the demo call but not at the exec briefing'],reach:['Ask the Champion if you can run a working session with the team who would use this daily','Request a process walkthrough — walk me through how you onboard a new customer today','Offer a sandbox or trial as users self-select in'],tactics:[{t:'Workflow walkthrough',b:'Map their current process step by step before showing anything. Concrete substitution beats abstract feature demos.'},{t:'Address the disruption fear directly',b:'Acknowledge switching costs upfront. Show your implementation timeline, training plan, and migration support.'},{t:'Let them drive the demo',b:'Give them a sandbox with their own use case loaded in. Self-directed exploration builds confidence.'},{t:'Make early wins easy',b:'Identify one quick win they can show their manager in week one. Users who get an early win become internal evangelists.'}],bizcase:'Users do not buy on ROI — they buy on whether this will make their day easier. Show time saved per task, reduction in status-update meetings, fewer tools to context-switch between. Tie AI features to relief from manual work.',ibg:'#e6f1fb',ic:'#0c447c',btnStyle:'background:#e6f1fb;color:#0c447c;border-color:transparent;font-weight:500'},
  t:{label:'T — Technical buyer',name:'Technical buyer',role:'Gatekeeper for security, integrations, and architecture',who:'Head of IT, VP or Director of Engineering, Salesforce Admin, or Enterprise Architect. For Cloud Coach — which lives on Salesforce — the Salesforce admin or platform architect is often the critical technical voice.',identify:['Asks about APIs, data residency, SSO, and permissioning early','Wants to see security documentation or App Exchange listing','May not attend the business demo — needs a separate technical call','Asks what is the data model or what happens to our data if we cancel'],reach:['Ask if there is a Salesforce admin or IT lead to loop in for a technical review','Send a technical one-pager proactively after the first discovery call','Reference the App Exchange listing and the completed Salesforce security review'],tactics:[{t:'Lead with the Salesforce-native story',b:'Cloud Coach runs natively on Salesforce — no external data silo, no ETL, no separate login. For a Salesforce shop this is a major technical advantage.'},{t:'Bring the security review completion',b:'The Salesforce security review is complete — share it proactively. Technical buyers are used to vendors hand-waving security; documentation changes the conversation.'},{t:'Offer a separate technical sandbox call',b:'30 minutes with IT to walk through the data model, permissions, and API usage. Stops them from derailing the business demo.'},{t:'Map to their existing architecture',b:'Ask what other tools are in their stack before showing anything. Show exactly how Cloud Coach sits alongside their existing setup with no duplication.'}],bizcase:'Technical buyers do not approve budget but they can kill deals with a veto. Their business case is a risk case: security review passed, native to existing infrastructure, low implementation lift, defined rollback path.',ibg:'#e1f5ee',ic:'#085041',btnStyle:'background:#e1f5ee;color:#085041;border-color:transparent;font-weight:500'},
  e:{label:'E — Economic buyer',name:'Economic buyer',role:'Budget authority — the deal does not close without them',who:'CFO, COO, CEO in mid-market, or VP of Finance. They rarely attend early calls. For Cloud Coach enterprise motion this is the person who approves multi-year digital transformation spend.',identify:['Not usually in early discovery — if they are treat it as a major signal','Their questions are financial: payback period, cost vs build/buy, headcount impact','They respond to peer benchmarks and competitive risk more than feature lists','You will often meet them only once — make it count'],reach:['Ask the Champion directly who controls the budget and whether you can get 20 minutes with them','Never let the Champion present to the EB alone — equip them but ask to be present','Frame the request as executive alignment not a sales meeting','Use Frank strategically for EB-to-EB conversations after the Champion has primed them'],tactics:[{t:'Open with the strategic frame not the product',b:'The EB does not want a demo. They want to know: why now, why us, and what happens if we do not act? Every company has an AI mandate — Cloud Coach is the workflow layer answer.'},{t:'Quantify the cost of inaction',b:'Build a do-nothing case. How much is manual resource allocation costing? The EB responds to numbers they already care about.'},{t:'Use the 18-month transformation narrative',b:'For enterprise deals Cloud Coach is not a tool purchase — it is a digital transformation. Frame as phased investment: workflow automation then AI-assisted resource management then full agentic capability.'},{t:'Prepare the Champion to present ROI',b:'Build a one-page financial summary: total cost, expected efficiency gains, payback period, risk reduction. Keep it to three numbers max.'}],bizcase:'Three parts: (1) Cost reduction — hours of manual coordination eliminated in dollar value at loaded cost. (2) Revenue impact — faster onboarding equals faster time-to-value and lower churn risk. (3) Strategic positioning — Cloud Coach is the enterprise post-sales unification layer ahead of the AI mandate.',ibg:'#fbeaf0',ic:'#72243e',btnStyle:'background:#fbeaf0;color:#72243e;border-color:transparent;font-weight:500'}
};
function buildCute(){var nav=document.getElementById('cute-nav');Object.keys(cuteData).forEach(function(k){var d=cuteData[k];var b=document.createElement('button');b.className='npill';b.id='cn-'+k;b.textContent=d.label;b.onclick=function(){showCute(k);};nav.appendChild(b);});showCute('c');}
function showCute(k){var d=cuteData[k];document.querySelectorAll('#cute-nav .npill').forEach(function(b){b.style.cssText='';});document.getElementById('cn-'+k).style.cssText=d.btnStyle;var idH=d.identify.map(function(i){return'<span class="pill">'+i+'</span>';}).join('');var reH=d.reach.map(function(r){return'<div class="dot-row"><div class="dot dot-blue"></div><p>'+r+'</p></div>';}).join('');var taH=d.tactics.map(function(t){return'<div class="mc"><strong>'+t.t+'</strong><p>'+t.b+'</p></div>';}).join('');document.getElementById('cute-panel').innerHTML='<div class="card"><div style="display:flex;gap:12px;align-items:flex-start"><div style="width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:500;flex-shrink:0;background:'+d.ibg+';color:'+d.ic+'">'+k.toUpperCase()+'</div><div><h2 style="font-size:20px;font-weight:500;margin:0 0 2px">'+d.name+'</h2><p style="font-size:13px;color:#6b6b66;margin:0 0 10px">'+d.role+'</p><p style="font-size:13px;color:#5f5e5a;line-height:1.7;margin:0">'+d.who+'</p></div></div></div><div class="sec-label">How to identify them</div><div style="margin-bottom:16px">'+idH+'</div><div class="sec-label">How to reach them</div><div style="margin-bottom:16px">'+reH+'</div><div class="sec-label">Tactics</div><div class="grid2" style="margin-bottom:16px">'+taH+'</div><div class="sec-label">Building the business case</div><div class="accent-left"><p>'+d.bizcase+'</p></div>';}

var meddData={
  m:{label:'M — Metrics',letter:'M',name:'Metrics',ibg:'#eeedfe',ic:'#3c3489',btnStyle:'background:#eeedfe;color:#3c3489;border-color:transparent;font-weight:500',def:'The quantifiable value the customer expects to gain. Without agreed metrics there is no business case and no urgency.',cc:'Cloud Coach deals require an 18-month enterprise sales cycle. The ROI story must be specific enough to justify multi-year budget. Vague value statements will not survive a CFO review.',qualify:['What does success look like in 12 months?','How do you currently measure resource utilisation or onboarding cycle time?','What would a 20% reduction in project coordination time mean in dollar terms?','Is there a KPI tied to this problem that appears in exec reporting?'],tactics:[{t:'Build the before/after model',b:'Map their current state metrics then model the improved state with Cloud Coach. Put numbers on both sides.'},{t:'Tie to metrics they already report',b:'Ask what lands in the board pack or CEO dashboard. If PS margin is already tracked Cloud Coach value is measurable from day one.'},{t:'Use the AI mandate as an urgency metric',b:'Every prospect has an AI mandate. Cloud Coach workflow automation is the measurable first step toward that mandate.'},{t:'Validate with the Champion',b:'Get the Champion to pressure-test your numbers against internal data. A metric they helped build is one they will defend to the EB.'}],redflags:['No one can name a metric tied to the problem','They measure activity not outcomes','The Champion says the business case writes itself — it never does']},
  e:{label:'E — Economic buyer',letter:'E',name:'Economic buyer',ibg:'#e6f1fb',ic:'#0c447c',btnStyle:'background:#e6f1fb;color:#0c447c;border-color:transparent;font-weight:500',def:'The single person with budget authority and final sign-off. The one person who can say yes when everyone else says no.',cc:'For Cloud Coach enterprise motion this is typically a CFO, COO, or CEO. The current sales team is burning executive access too early — involving Frank before internal consensus is built.',qualify:['Who has final sign-off on a project of this size?','Has budget been allocated or does it need to be approved?','If the business case is compelling who writes the cheque?','Is there anyone above your level whose sign-off we would need?'],tactics:[{t:'Never go to the EB without the Champion prep',b:'The Champion must brief the EB before you enter the room. An unprepared EB meeting is a cold call at the worst possible moment.'},{t:'EB-to-EB via Frank',b:'Frank reaching out to a peer CEO or CFO lands differently than a sales rep. Use this asset only after the Champion has confirmed the EB is warm.'},{t:'One meeting three numbers',b:'Open with the strategic frame then land on three numbers: total investment, expected return, payback period. EBs decide fast when the numbers are clean.'},{t:'Frame as transformation not software',b:'A CFO approving a six-figure multi-year deal is not buying software — they are approving a digital transformation programme.'}],redflags:['You have never spoken to the EB directly','The Champion says they can approve it themselves — verify this','The EB keeps getting pushed back or is too busy','You involved Frank too early and burned the asset before consensus was built']},
  dc:{label:'D — Decision criteria',letter:'D',name:'Decision criteria',ibg:'#e1f5ee',ic:'#085041',btnStyle:'background:#e1f5ee;color:#085041;border-color:transparent;font-weight:500',def:'The formal and informal requirements the prospect will use to evaluate vendors. If you do not know the criteria you cannot control how you are being scored.',cc:'Prospects now filter on AI at the top of funnel. If AI capability is not in your decision criteria response you may not make the shortlist. The Percursive situation showed what happens when a competitor maps to criteria you ignored.',qualify:['What does your ideal solution look like?','Are there must-haves versus nice-to-haves on your evaluation list?','Is AI capability a formal requirement or a preference?','Are you evaluating other vendors and what are they doing well?','Who else is involved in setting the evaluation criteria?'],tactics:[{t:'Get the criteria in writing early',b:'Ask the Champion to share the RFP or scoring matrix. If there is not one offer to help build it — you will naturally influence the criteria in your favour.'},{t:'Lead with Salesforce-native as a criterion',b:'Reframe the evaluation to include infrastructure fit. Cloud Coach running natively on Salesforce is a major advantage for Salesforce shops.'},{t:'Add AI workflow ownership as a criterion',b:'Help the prospect articulate what AI-readiness means in a PSA tool. Owning the workflow layer is a position Percursive cannot match on depth.'},{t:'Map every criterion to a proof point',b:'Build a matrix: their stated criteria on the left, your evidence on the right. Share it with the Champion so they can use it internally.'}],redflags:['You do not know what they are evaluating on','Criteria keep changing — political instability inside the account','A competitor was involved in setting the criteria','AI is listed as a must-have and you have not addressed it yet']},
  dp:{label:'D — Decision process',letter:'D',name:'Decision process',ibg:'#faeeda',ic:'#633806',btnStyle:'background:#faeeda;color:#633806;border-color:transparent;font-weight:500',def:'How the decision will actually be made — who is involved, in what sequence, and by when.',cc:'Cloud Coach enterprise deals have cycles up to 18 months. Without understanding the decision process you cannot forecast accurately or build the urgency needed to keep momentum.',qualify:['Walk me through how a decision like this typically gets made here','Who else needs to be involved or sign off before you can move forward?','Is there a formal procurement or legal review process?','What does your timeline look like?','What would cause this to stall or not happen this year?'],tactics:[{t:'Map the decision committee explicitly',b:'Ask the Champion to identify everyone who touches this decision — approvers, influencers, blockers. You need to know about the IT veto before it happens.'},{t:'Establish a mutual action plan',b:'Build a shared document with both sides steps, owners, and dates. A Champion who co-authors the plan is accountable to it.'},{t:'Identify the paper process early',b:'Procurement and legal can add 30-90 days to a close. Ask about this in discovery — not at the end.'},{t:'Create a reason to decide',b:'Long sales cycles die from inertia. Build in a compelling event: a renewal window, an upcoming board meeting, a competitor threat.'}],redflags:['No clear timeline or decision date','Every call ends with we will need to discuss internally','You have not met anyone beyond the Champion','The process keeps changing or getting extended']},
  p:{label:'P — Paper process',letter:'P',name:'Paper process',ibg:'#faece7',ic:'#712b13',btnStyle:'background:#faece7;color:#712b13;border-color:transparent;font-weight:500',def:'The legal, procurement, and contractual steps required to convert a verbal yes into a signed contract. Often the hidden deal-killer.',cc:'Enterprise deals at Cloud Coach target size will involve procurement review, legal redlines, and a Salesforce partner agreement review. The security review situation showed that compliance steps can appear late and derail timelines.',qualify:['Once we reach agreement what does the contract sign-off process look like?','Is there a procurement team or legal department who reviews vendor contracts?','Do you use a standard vendor agreement or will you need to redline ours?','Are there compliance or information security approvals required?','Who has authority to sign a contract of this size?'],tactics:[{t:'Start paper process conversations in mid-funnel',b:'Do not wait until you have a verbal yes. At Stage 3 or 4 ask about legal and procurement. A deal closing in March needs procurement conversations in January.'},{t:'Provide a clean contract early',b:'Send your standard MSA and order form as early as appropriate. Procurement teams redline faster when they have something to react to.'},{t:'Identify the signatory',b:'The person who signs is often not the EB you have been speaking to. Know who signs and make sure the Champion has briefed them.'},{t:'Use the App Exchange as a trust signal',b:'Being on the Salesforce App Exchange with a completed security review means Cloud Coach has already passed vendor due diligence. Highlight this with procurement.'}],redflags:['Legal review has not been mentioned and you are at late stage','Prospect uses a complex vendor onboarding process you just discovered','The signatory is someone you have never spoken to','Contract is with a PE-backed entity — parent company approval may be needed']},
  i:{label:'I — Identify pain',letter:'I',name:'Identify pain',ibg:'#fbeaf0',ic:'#72243e',btnStyle:'background:#fbeaf0;color:#72243e;border-color:transparent;font-weight:500',def:'The specific business-level problem the prospect needs to solve. Pain must be felt by someone with power or it will not drive a decision.',cc:'The sales team is demoing features before establishing pain. Real pain points are: manual PS coordination at scale, inability to onboard customers fast enough, resource allocation in spreadsheets, and lack of an AI narrative for the board.',qualify:['What is the biggest operational challenge in your post-sales or PS motion right now?','How are you currently handling resource allocation and capacity planning?','When a customer onboarding goes wrong what does that cost you?','Is your PS team able to scale without proportionally growing headcount?','Has your board or CEO asked for an AI strategy?'],tactics:[{t:'Pain before product always',b:'Do not open a screen share until you have articulated their pain back to them and they have confirmed it. Make sure you are solving a problem they have acknowledged out loud.'},{t:'Quantify the pain',b:'Soft pain does not buy software. Help the prospect put a number on it — even a rough one. The act of quantifying creates ownership.'},{t:'Connect pain to the AI mandate',b:'Every prospect has been told by their CEO to have an AI strategy. Cloud Coach workflow layer is a credible first step toward that mandate.'},{t:'Use Dylan for pain validation',b:'Dylan as Head of PS can speak peer-to-peer with the prospect PS or CS leader. A practitioner validating the pain is more credible than a sales rep describing it.'}],redflags:['Pain is described as a nice to have improvement','Only user-level team feels the pain — no executive-level pain identified','The Champion cannot articulate what happens if nothing changes','Pain was described in the first call but never revisited or quantified']},
  ch:{label:'C — Champion',letter:'C',name:'Champion',ibg:'#eaf3de',ic:'#27500a',btnStyle:'background:#eaf3de;color:#27500a;border-color:transparent;font-weight:500',def:'An internal advocate with influence who will sell on your behalf when you are not in the room. A Champion has personal stake, access to power, and the credibility to move the deal internally.',cc:'The current sales team is not qualifying for true Champions — they are treating any engaged contact as one. A real Champion will push back on internal resistance, secure time with the EB, and co-author the business case.',qualify:['Is this person personally invested in solving this problem?','Do they have access to the EB and the political capital to use it?','Have they sold something internally before and won?','Will they take actions between your calls without being chased?','Do they know the internal objections and have a plan to handle them?'],tactics:[{t:'Test Champion strength early',b:'Give them a small ask between calls. A real Champion does it. A contact who never takes action between calls is not a Champion.'},{t:'Champion enablement kit',b:'Build them a toolkit: a one-page business case summary, competitive comparison, reference customer story, ROI model. The easier you make it to sell internally the more they will.'},{t:'Coach them on the EB conversation',b:'Role-play the internal business case presentation with them. A Champion who feels prepared is more likely to actually schedule the EB meeting.'},{t:'Protect the Champion',b:'Do not put them in difficult positions. Your Champion reputation is your deal fuel — do not undermine their credibility with their colleagues.'}],redflags:['Your main contact avoids connecting you to anyone senior','They have never initiated contact — you always reach out first','They say they will try to get time with the CFO but never do','They have no view on internal objections — they are not plugged in']},
  co:{label:'C — Competition',letter:'C',name:'Competition',ibg:'#f1efe8',ic:'#444441',btnStyle:'background:#f1efe8;color:#444441;border-color:transparent;font-weight:500',def:'A full picture of who else is in the deal — direct competitors, the status quo (do nothing), and build-internally options.',cc:'Percursive shipped a near-identical feature set after seeing Cloud Coach pre-launch marketing — and the team was not prepared. The do-nothing option is also dangerous given the 18-month development runway.',qualify:['Are you evaluating any other solutions for this?','Have you looked at building internally or extending your existing Salesforce config?','What do you like about what you have seen from other vendors?','Is Percursive or any other PSA tool in the conversation?','What would make you choose to do nothing or delay this decision?'],tactics:[{t:'Know Percursive gaps not just Cloud Coach strengths',b:'Percursive copied the marketing messaging but likely does not have the depth of workflow capability or the Salesforce-native architecture. Build a specific factual comparison.'},{t:'Reframe do-nothing as the most expensive option',b:'Build a cost-of-delay calculation — every month without Cloud Coach is X hours of manual coordination, X days of delayed onboarding, X in PS margin leakage.'},{t:'Use the AI acquisition roadmap carefully',b:'The incoming bolt-on AI acquisition is a differentiator — use it to neutralise you do not have enough AI capability yet objections without overpromising on dates.'},{t:'Compete on depth not features',b:'Percursive can match a feature list. They cannot match 15 years of enterprise PS workflow experience, a completed Salesforce security review, and a post-sales unification roadmap.'}],redflags:['You do not know who else is in the deal','The Champion stops sharing information about the evaluation','Prospect suddenly goes quiet after previously being engaged','They ask for references in a specific industry you have not served — a competitor seeded that ask']}
};
function buildMedd(){var nav=document.getElementById('medd-nav');Object.keys(meddData).forEach(function(k){var d=meddData[k];var b=document.createElement('button');b.className='npill';b.id='mn-'+k;b.textContent=d.label;b.onclick=function(){showMedd(k);};nav.appendChild(b);});showMedd('m');}
function showMedd(k){var d=meddData[k];document.querySelectorAll('#medd-nav .npill').forEach(function(b){b.style.cssText='';});document.getElementById('mn-'+k).style.cssText=d.btnStyle;var qH=d.qualify.map(function(q){return'<span class="pill">'+q+'</span>';}).join('');var taH=d.tactics.map(function(t){return'<div class="mc"><strong>'+t.t+'</strong><p>'+t.b+'</p></div>';}).join('');var rfH=d.redflags.map(function(r){return'<div class="dot-row"><div class="dot dot-red"></div><p>'+r+'</p></div>';}).join('');document.getElementById('medd-panel').innerHTML='<div class="card"><div style="display:flex;gap:12px;align-items:flex-start"><div style="width:44px;height:44px;border-radius:50%;display:flex;align-items:center;justify-content:center;font-size:20px;font-weight:500;flex-shrink:0;background:'+d.ibg+';color:'+d.ic+'">'+d.letter+'</div><div><h2 style="font-size:20px;font-weight:500;margin:0 0 2px">'+d.name+'</h2><p style="font-size:13px;color:#5f5e5a;margin:0 0 10px;line-height:1.6">'+d.def+'</p><p style="font-size:13px;color:#5f5e5a;margin:0;line-height:1.7;padding-top:10px;border-top:1px solid #e8e6de"><span style="font-weight:600;color:#1a1a18">Cloud Coach context: </span>'+d.cc+'</p></div></div></div><div class="sec-label">Qualification questions</div><div style="margin-bottom:16px">'+qH+'</div><div class="sec-label">Tactics</div><div class="grid2" style="margin-bottom:16px">'+taH+'</div><div class="sec-label">Red flags</div><div>'+rfH+'</div>';}
var stageData=[{id:'s0',label:'Stage 0',name:'Discovery booked',owner:'SDR',forecast:'Not forecasted',pct:'1%',phase:'Recognize pain',cls:'s0a',objective:'Setting a meeting with a viable prospect',advance:'SDR books the meeting and AE completes meeting set with a viable prospect who has a plausible pain and Salesforce environment.',cute:[{code:'C',tag:'tag-c',cname:'Champion',note:'First pass — does the person who booked the meeting feel the pain personally or are they a gatekeeper? Identify likely Champion profile before the call.'},{code:'U',tag:'tag-u',cname:'User',note:'Understand the job title and role of who you are meeting. Are they a user-level contact or someone with more influence?'}],medd:['I — Research the prospect industry and likely PS/onboarding challenges before the call. Have a pain hypothesis ready.','M — Identify any public data on their growth rate, team size, or PS complexity to frame value.','C (Competition) — Know if they are a current Percursive or competitor customer before walking in.'],redflags:['Meeting booked by someone with no operational responsibility — likely low-influence','No information available about the company PS or CS function','SDR cannot articulate why this account was targeted beyond an inbound keyword match','Contact is a junior analyst with no path to a decision maker'],ccmust:['Do we know why this prospect booked — inbound, outbound, or referral?','Is the company size and vertical aligned with our ICP?','Do we have a pain hypothesis before the first call?','Has the SDR identified at least one likely CUTE persona based on title?','Is there an existing Salesforce footprint at this account?']},{id:'s1',label:'Stage 1',name:'Qualified',owner:'AE',forecast:'Pipeline',pct:'2%',phase:'Launch initiative',cls:'s1a',objective:'Setting a follow-up meeting or demo to understand the prospect business problem',advance:'AE confirms pain, surfaces initial metrics, identifies Champion candidate, and has a named EB. Prospect agrees to a product presentation.',cute:[{code:'C',tag:'tag-c',cname:'Champion',note:'Most critical stage for Champion identification. Do not advance without knowing who your Champion is. They must show personal investment — not just engagement.'},{code:'U',tag:'tag-u',cname:'User',note:'Identify the day-to-day operators who feel the pain. Confirm which roles would use Cloud Coach.'},{code:'T',tag:'tag-t',cname:'Technical buyer',note:'Begin mapping the technical landscape. Flag the Salesforce admin or IT lead early — do not wait until Stage 3.'},{code:'E',tag:'tag-e',cname:'Economic buyer',note:'Do not engage yet — but identify who they are. Ask the Champion who would approve a project of this size. Get the name. Do not reach out.'}],medd:['I — Pain must be articulated in the prospect own words by end of this stage.','M — Surface high-level KPIs. What do they measure today?','DC — Begin uncovering initial requirements. Is Salesforce-native required? Is AI on the evaluation list?','CH — Emerging Champion must show vested interest. Test with a small ask between calls.','C — Name any competitors. Do they already have a PSA tool?'],redflags:['AE cannot name a specific pain point after discovery — only vague interest','No one on the call had operational ownership of the problem','Prospect could not articulate what success looks like','Budget has not been mentioned in any form','Champion candidate has taken no action between calls','AI is on their radar but you have not positioned Cloud Coach workflow layer story'],ccmust:['Can we state the prospect pain in their own words?','Have we identified a Champion candidate who has taken at least one unprompted action?','Do we know the high-level metrics they track?','Do we know if Salesforce is in their stack?','Have we named the Economic Buyer even if we have not met them?','Do we know whether any competitors are in the conversation?','Is AI on their requirements list and have we positioned the workflow layer story?']},{id:'s2',label:'Stage 2',name:'Initial demo',owner:'AE',forecast:'Pipeline',pct:'15%',phase:'Evaluate solutions',cls:'s2a',objective:'Confirm mutual opportunity to partner and address the customer business problem',advance:'Mutual confirmation Cloud Coach can solve the problem. Champion is actively engaged. Next call scheduled with additional stakeholders.',cute:[{code:'C',tag:'tag-c',cname:'Champion',note:'Champion must be confirmed — not just suspected. They should be helping prepare the demo, sharing internal context, and connecting you to other stakeholders.'},{code:'U',tag:'tag-u',cname:'User',note:'Users should be present in this demo. Use the workflow walkthrough approach — show their day in Cloud Coach, not a generic demo.'},{code:'T',tag:'tag-t',cname:'Technical buyer',note:'If not already in the conversation flag this now. Request a separate technical call. Do not let them derail the business demo.'},{code:'E',tag:'tag-e',cname:'Economic buyer',note:'Still do not engage directly. But the Champion should be briefing the EB after this demo. Confirm this will happen.'}],medd:['I — Pain must be quantified by this stage — not just named. Work with the Champion to put a number on it.','M — Agree on the metrics that will define success. Quantified impact such as save 10 FTE-hours per week.','DC — Confirm whether AI is a formal requirement. Position Cloud Coach workflow layer ownership explicitly.','C — Name all competitors. Understand what they like about each.','CH — Champion should be actively socialising Cloud Coach internally. They should have collateral to share.','DP — Begin mapping who else needs to be involved and what the internal process looks like.'],redflags:['Demo was to one person with no other stakeholders present — single-threaded deal','Prospect responded positively but cannot articulate a specific problem it solves','Champion has not introduced you to anyone else after multiple calls','AI came up in the demo and you did not have a clear answer — Percursive risk','Metrics conversation was skipped or deflected','No agreement on next steps at the end of the call'],ccmust:['Can we quantify the pain in dollar, time, or risk terms validated by the prospect?','Has the Champion introduced us to at least one other stakeholder?','Do we know the full list of competitors being evaluated?','Have we explicitly positioned Cloud Coach AI workflow layer?','Do we know enough about their decision process to forecast accurately?','Has the Champion confirmed they will brief the EB?','Have we requested a technical call with the Salesforce admin or IT lead?']},{id:'s3',label:'Stage 3',name:'In-depth review',owner:'AE',forecast:'Best case',pct:'45%',phase:'Evaluate solutions',cls:'s3a',objective:'Presented solution to the business problem and the proposal is being reviewed internally',advance:'EB identified and briefed. ROI model validated. Technical review complete. Champion endorses. Decision criteria and process fully mapped.',cute:[{code:'C',tag:'tag-c',cname:'Champion',note:'Champion is now your internal sales rep. They should be presenting the business case internally without you. Equip them fully — ROI model, one-pager, competitive comparison.'},{code:'T',tag:'tag-t',cname:'Technical buyer',note:'Technical review must happen in this stage. Complete the Salesforce-native architecture walkthrough. Provide the security review documentation. Get technical sign-off.'},{code:'E',tag:'tag-e',cname:'Economic buyer',note:'Time to confirm whether the Champion has briefed the EB. If not, coach them to do so now. The EB should know Cloud Coach exists before Stage 4.'},{code:'U',tag:'tag-u',cname:'User',note:'Users should have had a sandbox or workflow walkthrough by this stage. Identify whether user-level resistance exists — it can kill deals even when the Champion is strong.'}],medd:['EB — Must be identified by name. Champion should have briefed them. Confirm.','M — ROI model built with prospect data — not a generic calculator.','DC — All formal criteria confirmed and mapped to Cloud Coach proof points.','DP — Full decision committee mapped. Timeline established. Procurement or legal steps surfaced.','PP — First mention of legal, security, and procurement requirements. Do not wait until Stage 4.','C — Competitive strengths and weaknesses confirmed. Champion can articulate why Cloud Coach wins.','CH — Champion endorses Cloud Coach recommendation internally.'],redflags:['EB has still not been briefed — the Champion is stalling or lacks access','Technical review keeps getting delayed — a hidden blocker','ROI model uses generic not prospect-specific numbers','Decision criteria keep shifting — political instability or competitor influence','No timeline has emerged — deal has no urgency','Champion has gone quiet or is no longer taking your calls','Paper process has not been discussed — a legal or procurement surprise is coming'],ccmust:['Do we have a named EB and confirmation they have been briefed?','Is our ROI model built on their data and validated by the Champion?','Have we completed or scheduled the technical review?','Do we know every member of the decision committee?','Have we surfaced any paper process requirements?','Can the Champion articulate why Cloud Coach wins against each named competitor?','Is there a compelling event driving a decision timeline?']},{id:'s4',label:'Stage 4',name:'Business case',owner:'AE',forecast:'Commit',pct:'85%',phase:'Negotiate',cls:'s4a',objective:'Achieve internal buy-in across multiple stakeholders, understand where the budget will come from, and get verbal commitment',advance:'Verbal yes from EB. Budget confirmed. Paper process in motion. Champion actively shepherding. No outstanding technical or legal blockers.',cute:[{code:'E',tag:'tag-e',cname:'Economic buyer',note:'This is the EB stage. You must have a direct meeting — not through the Champion. Use Frank for EB-to-EB if needed. Come with three numbers: total investment, ROI, payback period.'},{code:'C',tag:'tag-c',cname:'Champion',note:'Champion is actively shepherding approvals internally. They should be telling you what is happening in internal meetings. If they go dark the deal is at serious risk.'},{code:'T',tag:'tag-t',cname:'Technical buyer',note:'Technical sign-off should be confirmed. Any outstanding technical objections must be resolved before the verbal yes.'},{code:'U',tag:'tag-u',cname:'User',note:'Internal stakeholders should be bought in at the user level. User resistance surfacing at this stage can delay or derail.'}],medd:['EB — Direct meeting with EB. Present the final ROI business case. Get verbal yes.','M — Final ROI and business case validated by EB. Numbers must be theirs not ours.','PP — Legal, security, and procurement process confirmed and in motion. Contract timeline established.','DC/DP — All decision criteria and process boxes checked. No open items.','CH — Champion confirms internal support across all stakeholders. No hidden objections remaining.','C — Competition neutralised. Champion confirms no other vendor is ahead.'],redflags:['You still have not had a direct conversation with the EB','Verbal yes was given but no contract timeline was established','A new stakeholder appears at this stage with concerns — deal was not multi-threaded','Legal or procurement flags a requirement that was never mentioned','Champion stops sharing internal feedback','EB meeting keeps getting postponed — deal is not a priority at executive level','Competition is still active and Champion cannot confirm Cloud Coach is the preferred choice'],ccmust:['Have we had a direct meeting with the EB — not via the Champion?','Has the EB given a verbal yes and confirmed budget?','Do we have a confirmed contract and legal review timeline?','Are all decision criteria formally met with documented proof points?','Has the Champion confirmed there are no remaining internal objections?','Is the paper process in motion — legal and procurement engaged?','Have we confirmed competition is neutralised?']},{id:'s5',label:'Stage 5',name:'Contract',owner:'AE',forecast:'Commit',pct:'90%',phase:'Negotiate',cls:'s5a',objective:'Stakeholders bought in, contract reviewed, budget and timeline confirmed, and agreement to move forward',advance:'Procurement and IT review complete. Contract signed. Implementation plan in place. Success metrics documented for renewal.',cute:[{code:'E',tag:'tag-e',cname:'Economic buyer',note:'Confirm the signatory — it may not be the EB you have been speaking to. Make sure they are briefed and ready to sign.'},{code:'C',tag:'tag-c',cname:'Champion',note:'Champion is managing the internal close process. Keep them informed of every step. Any delay on your side should be communicated immediately.'},{code:'T',tag:'tag-t',cname:'Technical buyer',note:'Security and IT review must be complete. Share Cloud Coach App Exchange security review documentation with their IT team if not already done.'},{code:'U',tag:'tag-u',cname:'User',note:'Begin implementation kickoff planning — getting users aligned to the onboarding process before signature reduces post-sale churn risk.'}],medd:['PP — Contracts redlined and in final review. Security and finance approvals complete or confirmed.','EB — Signatory identified and briefed. Champion actively shepherding final approvals.','C — No outstanding competitive threats. Confirm with Champion no other vendor is being reconsidered.','M — Success metrics agreed in contract or implementation plan. Sets foundation for renewal.'],redflags:['Contract redlines introduce a new commercial term that was not discussed','IT or security review raises a blocker not surfaced in Stage 3 or 4','Champion goes quiet during the contract stage — internal politics may have shifted','Signatory is unavailable and no delegation of authority has been established','Prospect requests a significant scope or pricing change — buyer remorse signal','Close date slips more than two weeks without a clear reason'],ccmust:['Is the signatory identified, confirmed, and briefed on the deal?','Are all legal and security review items resolved?','Is the implementation and onboarding plan agreed?','Have we confirmed success metrics that will anchor the renewal conversation?','Is the Champion still actively engaged and shepherding the final steps?','Do we have a firm signature date — not a target, a confirmed date?']}];
function buildStage(){var nav=document.getElementById('stage-nav');stageData.forEach(function(s){var b=document.createElement('button');b.className='npill';b.id='sn-'+s.id;b.textContent=s.label+': '+s.name;b.onclick=function(){showStage(s.id);};nav.appendChild(b);});showStage('s0');}
function showStage(id){var s=stageData.find(function(x){return x.id===id;});document.querySelectorAll('#stage-nav .npill').forEach(function(b){b.className='npill';});document.getElementById('sn-'+id).classList.add(s.cls);var cuteH=s.cute.map(function(c){return'<div class="mc"><strong><span class="'+c.tag+'" style="margin-bottom:6px">'+c.code+' — '+c.cname+'</span></strong><p>'+c.note+'</p></div>';}).join('');var mH=s.medd.map(function(m){return'<div class="dot-row"><div class="dot dot-blue"></div><p>'+m+'</p></div>';}).join('');var rfH=s.redflags.map(function(r){return'<div class="dot-row"><div class="dot dot-red"></div><p>'+r+'</p></div>';}).join('');var ccH=s.ccmust.map(function(q){return'<div class="dot-row"><div class="dot dot-green"></div><p>'+q+'</p></div>';}).join('');document.getElementById('stage-panel').innerHTML='<div class="card"><div><h2 style="font-size:18px;font-weight:500;margin:0 0 4px">'+s.label+': '+s.name+'</h2><p style="font-size:13px;color:#5f5e5a;margin:0 0 10px">'+s.objective+'</p><div>'+['Owner: '+s.owner,'Forecast: '+s.forecast,'Probability: '+s.pct,'Phase: '+s.phase].map(function(x){return'<span class="meta-chip">'+x+'</span>';}).join('')+'</div></div><div style="margin-top:12px;padding-top:12px;border-top:1px solid #e8e6de"><p style="font-size:11px;font-weight:600;text-transform:uppercase;letter-spacing:0.07em;color:#9b9990;margin:0 0 4px">Gate to advance</p><p style="font-size:13px;color:#5f5e5a;margin:0;line-height:1.6">'+s.advance+'</p></div></div><div class="sec-label">CUTE personas to engage this stage</div><div class="grid2" style="margin-bottom:4px">'+cuteH+'</div><div class="sec-label">MEDDPICC focus this stage</div><div style="margin-bottom:4px">'+mH+'</div><div class="sec-label">Red flags — do not advance if present</div><div style="margin-bottom:4px">'+rfH+'</div><div class="sec-label">Cloud Coach must be able to answer before advancing</div><div style="margin-bottom:16px">'+ccH+'</div>';}
var objData=[
  {id:'o1',label:'Ending a call with no decision',
    what:'The call has gone well. The prospect is engaged. There is no obvious objection on the table. But the rep wraps up without making a commercial ask — and signals that it is fine if nothing comes of it.',
    quotes:[{text:'"Ultimately, if nothing does come from this, I would love to still keep a relationship with you all."'}],
    why:'The prospect had not expressed any hesitation. By raising the possibility of losing the deal unprompted, the rep signals they do not believe it is going to close. Prospects take their cues from reps. When the rep projects low confidence, the prospect urgency drops accordingly. A warm call ends without a next step, and warm calls without next steps go cold.',
    say:['"Before we wrap — what does your decision timeline look like, and who else do we need to involve to get there?"','"Based on what we covered today, is there anything that would stop you from moving forward? And what would the path to a decision look like on your end?"'],
    principle:'A call that ends without a commercial ask is a call that did not happen. You can be warm, relationship-oriented, and still ask for the next step. These are not in conflict.',note:null},
  {id:'o2',label:'Prospect signals a delay',
    what:'The prospect says they are not ready yet — procurement, timing, internal priorities. The rep accepts it immediately, sets a vague future touchpoint, and pre-emptively absolves the prospect of any obligation to return.',
    quotes:[{text:'"No worries at all, let\'s plan on reconnecting early Q2. If you don\'t end up booking time, no hard feelings there."'}],
    why:'Delays are information — but only if you ask what is behind them. A delay could mean budget timing, a champion who has not briefed the EB yet, or a soft no dressed up as a scheduling issue. Accepting a delay without interrogating it means you cannot tell the difference between a deal that needs 30 more days and one that is already dead.',
    say:['"I want to make sure I understand the delay — is this a budget timing issue, a prioritisation issue, or something else? Because the answer changes what we do next."','"When you say the timing is not right — help me understand what would need to be true for it to be right."','"Can we agree on what the specific trigger is that would move this forward, and I will reach back out when that is approaching?"'],
    principle:'"No hard feelings" is not a sales technique. A deal delayed without a defined trigger is a deal that will die quietly. Always leave a delay with a specific condition attached, not a vague date.',note:null},
  {id:'o3',label:'Product or fit objection raised',
    what:'The prospect raises a concern — about Salesforce nativity, product depth, pricing, or fit. The rep validates it, says "that totally makes sense," and moves on. The objection is never examined, never challenged, and never resolved.',
    quotes:[{text:'Prospect: "The only concern is that it\'s so built into Salesforce. You can have their own instance outside of Salesforce. That\'s a comparison we\'ve been seeing."\n\nRep: "Cool. No, that makes sense."'}],
    why:'Validating an objection without probing it signals to the prospect that the rep agrees the concern is valid. Acknowledging an objection is different from validating its conclusion. You can accept that the concern is real without accepting that it is a dealbreaker.',
    say:['"Tell me more about that — is that a dealbreaker for you, or something we would need to solve before you would move forward?"','"I hear you on that — it is actually something we address directly. Can I walk you through how we think about it, and then you tell me if it still holds?"','"That comparison comes up. What specifically are you seeing as the trade-off? Because I want to make sure we address the actual gap, not what I assume the gap to be."'],
    principle:'The right response to an objection is always a question. Keep the deal alive long enough to find out whether the concern is real or assumed.',
    note:'The Salesforce-native objection will come up. Being native to Salesforce means no data silo, no separate login, no ETL, and inherited security. For any Salesforce shop, that is an advantage. The objection only wins when it goes unchallenged.'},
  {id:'o4',label:'Prospect has a blocker',
    what:'The prospect identifies a genuine obstacle — a licence upgrade, a budget cycle, a technical prerequisite. The rep internalises the blocker as their problem, sympathises with the difficulty, and in some cases helps the prospect find a path that does not involve Cloud Coach.',
    quotes:[{text:'"Godspeed to you, my friend, because working with Salesforce on that type of stuff can be a challenge."'},{text:'"I\'ll send you over a quick note with some of the tools that I found, if you want to check them out."'}],
    why:'Blockers are not the same as deal-killers. A Salesforce licence upgrade is a cost — the question is not whether it costs something, it is whether Cloud Coach value justifies that cost. When a rep validates the blocker and offers competitor alternatives, they have made the commercial decision for the prospect.',
    say:['"That is a real hurdle — I am not going to pretend it is not. But before you decide it is not worth it, let me make the case for why it might be. Can I send you a one-pager that quantifies the ROI before you decide?"','"The upgrade is a real step. What I would want you to have is a clear picture of what the return looks like, so the decision is an informed one. Can we do that before you rule it out?"'],
    principle:'Never send a prospect competitor recommendations. Your job is to make the case for Cloud Coach, not to curate the alternatives.',note:null},
  {id:'o5',label:'Prospect asks about pricing',
    what:'The prospect asks for a rough number — often because they need to take something to a financial decision-maker. The rep deflects to an email or a future demo rather than giving a range in the moment.',
    quotes:[{text:'Prospect: "Can you give me a rough idea of pricing so I can take it to my financial person?"\n\nRep: "I\'ll outline some of that stuff in the email. I\'d love to get you in front of a demo for 60 minutes."'}],
    why:'A prospect asking for pricing to take to their financial person is a buying signal — they are signalling internal intent. Deferring to an email delays the internal conversation they are trying to have. Emails get deprioritised, lost, or never actioned.',
    say:['"Let me give you a rough range right now so you have something real to work with. For a team your size, implementation is typically in the [X-Y] range. Does that fit what you are working with?"','"Let me give you a ballpark now so you have something for that conversation. That way the email fills in the specifics rather than being the first number they see."'],
    principle:'Pricing questions are buying signals. Treat them that way. A rep who defers every pricing question to an email is a rep who never gets to a commercial conversation.',note:null},
  {id:'o6',label:'Long-running deal, no urgency',
    what:'A deal has been in motion for weeks or months. There has been investment on both sides — trials, demos, calls, reviews. But there is no commercial ask anywhere in the process. Every next step is another meeting.',
    quotes:[{text:'"I thought maybe there might be some demonstrations that we\'d go through, but I\'ll give you back 45 minutes of your time."\n\n(Said on a $93K deal, five months into a trial, in a 17-minute call with no commercial ask.)'},{text:'"I\'ll send a recording, and then we\'ll wait for next steps for the RFP."\n\n(Said at the close of a $53K demo with an engaged prospect. The deal went to a competitor six weeks later.)'}],
    why:'Long sales cycles do not kill deals — the absence of urgency does. A prospect who has been in a trial for five months without a commercial conversation has been trained by the rep to believe no decision is required.',
    say:['"We are five months into this — I want to make sure we are moving toward something. What would need to be true for you to make a decision by the end of next month?"','"I do not want to keep taking up your team\'s time without a clear path forward. Can we talk about what a decision looks like on your end — timeline, stakeholders, and what you would need to feel confident?"','"Before I send this recording — what is the one thing that would make the difference between moving forward and not? I would rather know that now than find out in another call."'],
    principle:'Activity is not progress. Meetings are not milestones. A deal in motion for months without a commercial ask is not a live deal — it is a relationship. Relationships do not close. Commercial conversations do.',note:null}
];
function buildObj(){
  var nav=document.getElementById('obj-nav');
  objData.forEach(function(s){var b=document.createElement('button');b.className='npill';b.id='on-'+s.id;b.textContent=s.label;b.onclick=function(){showObj(s.id);};nav.appendChild(b);});
  showObj('o1');
}
function showObj(id){
  var s=objData.find(function(x){return x.id===id;});
  document.querySelectorAll('#obj-nav .npill').forEach(function(b){b.style.cssText='';});
  document.getElementById('on-'+id).style.cssText='background:#1a1a18;color:#fff;border-color:transparent;font-weight:500';
  var qH=s.quotes.map(function(q){return'<div class="gong-quote"><div class="gong-label">Gong recording quote</div><p>'+q.text.replace(/\n\n/g,'<br><br>')+'</p></div>';}).join('');
  var sayH=s.say.map(function(t){return'<div class="say-row"><div class="say-dot"></div><p>'+t+'</p></div>';}).join('');
  var noteH=s.note?'<div class="sec-label">On this specific objection</div><div class="why-box"><p>'+s.note+'</p></div>':'';
  document.getElementById('obj-panel').innerHTML=
    '<div class="card"><p style="font-size:13px;color:#5f5e5a;line-height:1.7;margin-bottom:12px">'+s.what+'</p>'+qH+
    '<div class="sec-label">Why it costs you the deal</div><div class="why-box"><p>'+s.why+'</p></div>'+noteH+
    '<div class="sec-label">What to say instead</div>'+sayH+
    '<div class="principle-box"><p>'+s.principle+'</p></div></div>'+
    '<div class="rule-card"><h3>The one rule that covers all of it</h3><p class="big">"What would need to be true for us to move forward?"</p><p>Every call ends with either a commitment or a clear understanding of what stands in the way of one. Not a vague follow-up. Not a recording sent to a quiet inbox. A commitment to a next step, a decision, or a conversation with a specific person.</p></div>'+
    '<div class="footer-note">All quotes sourced directly from Gong call recordings, Oct 2025 – Mar 2026. No quotes have been paraphrased or altered. For internal use only.</div>';
}
var scenarios=[
  {id:'r1',label:'Scenario 1',group:'From the module',tag:'Ending a call',context:'You have just finished a 45-minute discovery call with Jennifer, a VP of Customer Success at a mid-market SaaS company. The call went well — she was engaged, asked good questions, and said Cloud Coach sounded interesting. There are no obvious objections on the table. The call is wrapping up.',prospect:'"This has been really helpful. I\'ll definitely share this with the team and we\'ll be in touch."'},
  {id:'r2',label:'Scenario 2',group:'From the module',tag:'Vague delay',context:'You are on a reconnect call with Phillip, a Director of Operations at a logistics company. He was warm on the first call three weeks ago. Today he says the timing is not right.',prospect:'"Things have got a bit busy on our end. I think we need to push this to next quarter. Can we reconnect in Q2?"'},
  {id:'r3',label:'Scenario 3',group:'From the module',tag:'Salesforce-native objection',context:'You are in a technical overview call. The prospect has been evaluating Cloud Coach for two weeks. Their IT lead has just joined the call.',prospect:'"Our main concern is that Cloud Coach is so tied to Salesforce. We\'ve been looking at a standalone tool that sits outside of Salesforce. That feels less risky to us."'},
  {id:'r4',label:'Scenario 4',group:'From the module',tag:'Licence blocker',context:'You are on a closing call with Marcus, a Head of Professional Services at a telecoms company. He has been engaged throughout. He has just revealed a blocker.',prospect:'"The problem is we\'re on Salesforce Essentials right now. We\'d need to upgrade to Enterprise before we could even deploy this. That\'s another conversation entirely and I\'m not sure we have the appetite for it right now."'},
  {id:'r5',label:'Scenario 5',group:'From the module',tag:'Pricing ask',context:'You are on a first follow-up call with Peg, a COO at a professional services firm. She has been positive throughout. At the end of the call she asks:',prospect:'"Before I go — can you give me a rough sense of what this would cost? I need to take something to my CFO before we go any further."'},
  {id:'r6',label:'Scenario 6',group:'From the module',tag:'Stalled trial',context:'You are on a check-in call with the Head of Operations at ProofPoint. They have been in a trial for four months. Usage has been moderate. There has been no commercial conversation.',prospect:'"Yeah the trial\'s been going fine. No major issues. We just haven\'t had time to sit down and really evaluate it properly."'},
  {id:'r7',label:'Scenario 7',group:'Additional',tag:'Committee deflection',context:'You are three calls into a deal with Adam, a Senior Director of CS at an enterprise software company. He has been your main contact throughout. You have asked twice about budget and next steps.',prospect:'"Look, I like what I\'m seeing — but this kind of decision goes through a committee. I can\'t really move this forward until I\'ve got buy-in from a few other people. I\'ll keep you posted."'},
  {id:'r8',label:'Scenario 8',group:'Additional',tag:'Competitor already in',context:'You are on an initial discovery call with a Director of Professional Services. Halfway through they mention something unexpected.',prospect:'"Just so you know, we\'re already in a trial with Percursive. We\'re only taking this call because our CEO wants us to make sure we\'ve looked at alternatives. We\'re pretty far down the road with them."'},
  {id:'r9',label:'Scenario 9',group:'Additional',tag:'Built it internally',context:'You are on a second call with a VP of Operations at a fast-growing fintech. She seemed interested on the first call but has come back with a new development.',prospect:'"Since we last spoke, our engineering team has actually started building something internally for this. It\'s early days but there\'s appetite to keep going with it. I\'m not sure it makes sense to look externally right now."'},
  {id:'r10',label:'Scenario 10',group:'Additional',tag:'Budget cycle',context:'You are on what was meant to be a closing call with a Director of Customer Operations. The business case has been approved internally in principle.',prospect:'"Everything looks good on our end — we want to do this. But our budget cycle doesn\'t open until October. There\'s nothing I can do before then. Can we pick this back up in September?"'},
  {id:'r11',label:'Scenario 11',group:'Additional',tag:'AI is a buzzword',context:'You are on a demo call and have positioned Cloud Coach workflow automation as a step toward the prospect AI mandate. The prospect pushes back.',prospect:'"Honestly, AI is a bit of a buzzword in our organisation right now. Our CEO talks about it but nobody really knows what it means for us practically. We\'re not going to buy something just because it has AI in the name."'},
  {id:'r12',label:'Scenario 12',group:'Additional',tag:'EB gatekeeper',context:'You have been working with Tom, a Senior Manager of PS, for six weeks. The deal is progressing but you have never spoken to the budget holder. You ask Tom about getting the CFO involved.',prospect:'"I don\'t think we need to involve Sarah at this stage. She\'s very busy and I\'d rather not put something in front of her until I\'m completely sure this is the right fit. Let\'s keep going for now."'}
];
var feedbackCache={};
function buildRplay(){
  var panel=document.getElementById('rplay-panel');
  var introHTML='<div class="rp-intro"><p>Read each prospect scenario, then type your response as you would deliver it on a live call. AI feedback will evaluate your commercial posture, objection handling, MEDDPICC alignment, and language — and provide a model response to compare against.</p></div>';
  var navHTML='<div class="nav-pills" id="rp-nav"></div>';
  var cardHTML='<div id="rp-card"></div>';
  panel.innerHTML=introHTML+navHTML+cardHTML;
  var nav=document.getElementById('rp-nav');
  scenarios.forEach(function(s){
    var b=document.createElement('button');b.className='npill';b.id='rn-'+s.id;
    b.textContent=s.label;
    b.onclick=function(){showScenario(s.id);};
    nav.appendChild(b);
  });
  showScenario('r1');
}
function showScenario(id){
  var s=scenarios.find(function(x){return x.id===id;});
  document.querySelectorAll('#rp-nav .npill').forEach(function(b){b.style.cssText='';});
  document.getElementById('rn-'+id).style.cssText='background:#1a1a18;color:#fff;border-color:transparent;font-weight:500';
  var savedFeedback=feedbackCache[id]?'<div class="feedback-box"><div class="feedback-header">AI Feedback</div><div class="feedback-body">'+feedbackCache[id]+'</div></div>':'';
  var savedResponse=feedbackCache[id+'_response']||'';
  document.getElementById('rp-card').innerHTML=
    '<div class="scenario-card">'+
    '<div class="scenario-header"><div><div class="scenario-num">'+s.group+' · '+s.label+'</div><h3 style="font-size:15px;font-weight:500;margin:4px 0 0">'+s.tag+'</h3></div><span class="scenario-tag">'+s.group+'</span></div>'+
    '<p style="font-size:13px;color:#5f5e5a;line-height:1.7;margin-bottom:0">'+s.context+'</p>'+
    '<div class="prospect-says"><div class="prospect-label">Prospect says</div><p>'+s.prospect+'</p></div>'+
    '<div class="sec-label">Your response</div>'+
    '<textarea class="rp-textarea" id="rp-input-'+id+'" placeholder="Type your response here — write it as you would say it on the call...">'+savedResponse+'</textarea>'+
    '<button class="rp-btn" id="rp-submit-'+id+'" onclick="submitResponse(\''+id+'\')">Get feedback</button>'+
    savedFeedback+
    '</div>';
}
function submitResponse(id){
  var s=scenarios.find(function(x){return x.id===id;});
  var input=document.getElementById('rp-input-'+id);
  var btn=document.getElementById('rp-submit-'+id);
  var response=input.value.trim();
  if(!response){alert('Please type your response before submitting.');return;}
  feedbackCache[id+'_response']=response;
  btn.disabled=true;btn.textContent='Getting feedback...';
  var existing=document.querySelector('.feedback-box');
  if(existing)existing.remove();
  var loadingDiv=document.createElement('div');
  loadingDiv.className='loading-indicator';loadingDiv.id='rp-loading-'+id;
  loadingDiv.textContent='Analysing your response...';
  btn.parentNode.insertBefore(loadingDiv,btn.nextSibling);
  var systemPrompt='You are a sales coaching AI for Cloud Coach, a professional services automation tool built natively on Salesforce. You evaluate sales rep responses to objections and prospect situations using four criteria: (1) Commercial posture — does the response move toward a decision or away from one? Does it signal confidence in Cloud Coach as the right solution? (2) Objection handling — does the rep acknowledge the concern without validating its conclusion? Do they probe before accepting? (3) MEDDPICC alignment — does the response advance qualification? Does it surface pain, metrics, decision process, or economic buyer information? (4) Language and tone — does the rep avoid low-confidence patterns like offering exits, accepting stalls without interrogating them, or validating objections without challenging them? Score each dimension 1-10 and provide specific, constructive feedback in 2-3 sentences per dimension. Then provide a model response of 3-5 sentences showing what a confident, well-positioned rep would say. Format your response as JSON with this exact structure: {"commercial_posture":{"score":7,"feedback":"..."},"objection_handling":{"score":8,"feedback":"..."},"meddpicc":{"score":6,"feedback":"..."},"language_tone":{"score":7,"feedback":"..."},"overall":"...","model_response":"..."} Return only valid JSON, no markdown, no preamble.';
  var userPrompt='Scenario: '+s.context+'\n\nProspect said: '+s.prospect+'\n\nRep response: '+response;
  fetch('https://api.anthropic.com/v1/messages',{
    method:'POST',
    headers:{'Content-Type':'application/json'},
    body:JSON.stringify({model:'claude-sonnet-4-20250514',max_tokens:1000,system:systemPrompt,messages:[{role:'user',content:userPrompt}]})
  }).then(function(r){return r.json();}).then(function(data){
    var loading=document.getElementById('rp-loading-'+id);if(loading)loading.remove();
    btn.disabled=false;btn.textContent='Get feedback';
    var text=data.content&&data.content[0]?data.content[0].text:'';
    var parsed;
    try{parsed=JSON.parse(text);}catch(e){parsed=null;}
    var html;
    if(parsed){
      var dims=[{key:'commercial_posture',label:'Commercial posture'},{key:'objection_handling',label:'Objection handling'},{key:'meddpicc',label:'MEDDPICC alignment'},{key:'language_tone',label:'Language and tone'}];
      var scoresHTML=dims.map(function(d){
        var item=parsed[d.key]||{};
        var score=item.score||0;
        var pct=Math.round(score*10);
        var col=score>=8?'#639922':score>=6?'#378add':'#e24b4a';
        return'<div style="margin-bottom:12px"><div style="display:flex;justify-content:space-between;margin-bottom:4px"><span style="font-size:12px;color:#5f5e5a">'+d.label+'</span><span style="font-size:12px;font-weight:500;color:'+col+'">'+score+'/10</span></div><div style="background:#f0efe8;border-radius:4px;height:6px;overflow:hidden"><div style="height:6px;border-radius:4px;background:'+col+';width:'+pct+'%"></div></div><p style="font-size:12px;color:#6b6b66;margin:6px 0 0;line-height:1.6">'+(item.feedback||'')+'</p></div>';
      }).join('');
      var modelHTML=parsed.model_response?'<div class="model-response"><div class="model-label">Model response</div><p>'+parsed.model_response+'</p></div>':'';
      var overallHTML=parsed.overall?'<p style="font-size:13px;color:#5f5e5a;line-height:1.7;margin-bottom:16px">'+parsed.overall+'</p>':'';
      html=overallHTML+scoresHTML+modelHTML;
    } else {
      html='<p style="font-size:13px;color:#5f5e5a;line-height:1.7">'+(text||'Something went wrong. Please try again.')+'</p>';
    }
    feedbackCache[id]=html;
    var fbDiv=document.createElement('div');
    fbDiv.className='feedback-box';
    fbDiv.innerHTML='<div class="feedback-header">AI Feedback</div><div class="feedback-body">'+html+'</div>';
    btn.parentNode.insertBefore(fbDiv,btn.nextSibling);
  }).catch(function(err){
    var loading=document.getElementById('rp-loading-'+id);if(loading)loading.remove();
    btn.disabled=false;btn.textContent='Get feedback';
    var fbDiv=document.createElement('div');
    fbDiv.className='feedback-box';
    fbDiv.innerHTML='<div class="feedback-header">AI Feedback</div><div class="feedback-body"><p style="font-size:13px;color:#e24b4a">Something went wrong. Please check your connection and try again.</p></div>';
    btn.parentNode.insertBefore(fbDiv,btn.nextSibling);
  });
}
buildCute();buildMedd();buildStage();buildObj();buildRplay();
</script>
